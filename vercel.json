{
  "version": 2,
   "builds": [
    {
      "src": "dist/api/index.js",
      "use": "@vercel/node"
    },
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": { "distDir": "build" }
    }
  ],
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/dist/api/index.js" },
    { "source": "/(.*)", "destination": "/public/index.html" }
  ]
}
